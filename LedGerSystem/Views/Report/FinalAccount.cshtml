@model FinalAccountViewModel
@{
    ViewData["Title"] = "Final Account";
}

<div class="d-flex flex-wrap justify-content-between align-items-center mb-3 gap-2">
    <h1 class="h4 mb-0">Final Account</h1>
    <div class="d-flex gap-2 align-items-center">
        <form method="get" class="d-flex gap-2 align-items-center">
            <label class="small text-muted mb-0">As of</label>
            <input type="date" name="date" value="@Model.AsOfDate.ToString("yyyy-MM-dd")" class="form-control form-control-sm" />
            <button type="submit" class="btn btn-sm btn-primary">View</button>
        </form>
        <a asp-action="FinalAccount" asp-route-date="@Model.AsOfDate.ToString("yyyy-MM-dd")" asp-route-export="excel" class="btn btn-sm btn-outline-success">Excel</a>
    </div>
</div>

<div class="row g-3 mb-3">
    <div class="col-md-3 col-6">
        <div class="card border-0 shadow-sm"><div class="card-body py-3">
            <div class="small text-muted">Total Credit</div>
            <div class="h5 mb-0 text-success">@Model.TotalCredit.ToString("N2")</div>
        </div></div>
    </div>
    <div class="col-md-3 col-6">
        <div class="card border-0 shadow-sm"><div class="card-body py-3">
            <div class="small text-muted">Total Debit</div>
            <div class="h5 mb-0 text-danger">@Model.TotalDebit.ToString("N2")</div>
        </div></div>
    </div>
    <div class="col-md-3 col-6">
        <div class="card border-0 shadow-sm"><div class="card-body py-3">
            <div class="small text-muted">Expenses</div>
            <div class="h5 mb-0">@Model.TotalExpenses.ToString("N2")</div>
        </div></div>
    </div>
    <div class="col-md-3 col-6">
        <div class="card border-0 shadow-sm bg-primary text-white"><div class="card-body py-3">
            <div class="small opacity-75">Profit</div>
            <div class="h5 mb-0">@Model.Profit.ToString("N2")</div>
        </div></div>
    </div>
</div>

<div class="row g-3">
    <div class="col-lg-6">
        <div class="card border-0 shadow-sm">
            <div class="card-header bg-white fw-semibold text-success">Credit (Receivable / Asset)</div>
            <table class="table table-sm mb-0">
                <thead class="table-light"><tr><th>Code</th><th>Name</th><th>Type</th><th class="text-end">Amount</th></tr></thead>
                <tbody>
                    @if (!Model.CreditLines.Any())
                    {
                        <tr><td colspan="4" class="text-muted text-center py-3">No credit items</td></tr>
                    }
                    else
                    {
                        foreach (var line in Model.CreditLines)
                        {
                            <tr>
                                <td>@line.Code</td>
                                <td>@line.Name</td>
                                <td class="small text-muted">@line.Category</td>
                                <td class="text-end">@line.Balance.ToString("N2")</td>
                            </tr>
                        }
                        <tr class="table-light fw-semibold">
                            <td colspan="3">Total</td>
                            <td class="text-end">@Model.TotalCredit.ToString("N2")</td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
    <div class="col-lg-6">
        <div class="card border-0 shadow-sm">
            <div class="card-header bg-white fw-semibold text-danger">Debit (Payable / Liability)</div>
            <table class="table table-sm mb-0">
                <thead class="table-light"><tr><th>Code</th><th>Name</th><th>Type</th><th class="text-end">Amount</th></tr></thead>
                <tbody>
                    @if (!Model.DebitLines.Any())
                    {
                        <tr><td colspan="4" class="text-muted text-center py-3">No debit items</td></tr>
                    }
                    else
                    {
                        foreach (var line in Model.DebitLines)
                        {
                            <tr>
                                <td>@line.Code</td>
                                <td>@line.Name</td>
                                <td class="small text-muted">@line.Category</td>
                                <td class="text-end">@line.Balance.ToString("N2")</td>
                            </tr>
                        }
                        <tr class="table-light fw-semibold">
                            <td colspan="3">Total</td>
                            <td class="text-end">@Model.TotalDebit.ToString("N2")</td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>

<p class="text-muted small mt-3 mb-0">
    Profit = Credit - Debit - Expenses = @Model.TotalCredit.ToString("N2") - @Model.TotalDebit.ToString("N2") - @Model.TotalExpenses.ToString("N2") = <strong>@Model.Profit.ToString("N2")</strong> BDT
</p>
