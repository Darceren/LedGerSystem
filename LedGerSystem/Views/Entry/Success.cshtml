@model List<LedGerSystem.Entities.LedgerTransaction>
@{
    ViewData["Title"] = "Saved";
    Layout = "_LayoutMobile";
}

@{
    var saved = ViewBag.SavedTransaction as LedGerSystem.Entities.LedgerTransaction;
}
<div class="text-center mb-4">
    <div class="display-6 text-success mb-2">&#10003;</div>
    <h1 class="h4 fw-bold">Transaction Saved</h1>
    @if (saved != null)
    {
        <p class="mb-1"><strong>@saved.TransNo</strong></p>
        <p class="text-muted small mb-0">@(saved.TransType?.NameEn) · @saved.Amount.ToString("N2") @saved.Currency</p>
    }
    else
    {
        <p class="text-muted mb-0">Your entry has been recorded.</p>
    }
</div>

<div class="d-grid gap-2 mb-4">
    <a asp-action="Create" class="btn btn-success btn-lg">New Entry</a>
    <a asp-controller="Home" asp-action="Index" class="btn btn-outline-secondary">Dashboard</a>
</div>

<div class="card border-0 shadow-sm">
    <div class="card-header bg-white fw-semibold">Recent Transactions</div>
    <ul class="list-group list-group-flush">
        @foreach (var item in Model)
        {
            <li class="list-group-item">
                <div class="d-flex justify-content-between">
                    <div>
                        <div class="fw-semibold">@(item.TransType?.NameEn ?? "Transaction")</div>
                        <div class="small text-muted">@(item.Party?.Code ?? "-") · @item.TransDate.ToString("yyyy-MM-dd HH:mm")</div>
                    </div>
                    <div class="text-end">
                        <div class="fw-semibold">@item.Amount.ToString("N2") @item.Currency</div>
                        <div class="small text-muted">@item.TransNo</div>
                    </div>
                </div>
            </li>
        }
    </ul>
</div>
