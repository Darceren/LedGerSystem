@model List<LedGerSystem.Entities.Party>
@{
    ViewData["Title"] = "Parties";
    var currentType = ViewBag.PartyType as byte?;
}

<div class="d-flex justify-content-between align-items-center mb-3">
    <h1 class="h4 mb-0">Parties</h1>
    <a asp-action="Create" asp-route-type="@currentType" class="btn btn-primary btn-sm">Add Party</a>
</div>

<ul class="nav nav-pills mb-3 flex-wrap gap-1">
    <li class="nav-item"><a class="nav-link @(currentType is null ? "active" : "")" asp-action="Index">All</a></li>
    <li class="nav-item"><a class="nav-link @(currentType == 1 ? "active" : "")" asp-action="Index" asp-route-type="1">Customers</a></li>
    <li class="nav-item"><a class="nav-link @(currentType == 2 ? "active" : "")" asp-action="Index" asp-route-type="2">Suppliers</a></li>
    <li class="nav-item"><a class="nav-link @(currentType == 3 ? "active" : "")" asp-action="Index" asp-route-type="3">Shufen</a></li>
    <li class="nav-item"><a class="nav-link @(currentType == 4 ? "active" : "")" asp-action="Index" asp-route-type="4">Other</a></li>
</ul>

<div class="card border-0 shadow-sm">
    <div class="table-responsive">
        <table class="table table-hover mb-0 align-middle">
            <thead class="table-light">
                <tr>
                    <th>Code</th>
                    <th>Name</th>
                    <th>Type</th>
                    <th>Final Side</th>
                    <th>Sort</th>
                    <th>Status</th>
                    <th></th>
                </tr>
            </thead>
            <tbody>
                @foreach (var item in Model)
                {
                    <tr class="@(!item.IsActive ? "table-secondary" : "")">
                        <td><strong>@item.Code</strong></td>
                        <td>@item.Name</td>
                        <td>@(item.PartyType switch { 1 => "Customer", 2 => "Supplier", 3 => "Shufen", _ => "Other" })</td>
                        <td>@(item.FinalAccountSide switch { 1 => "Credit", 2 => "Debit", _ => "-" })</td>
                        <td>@item.SortOrder</td>
                        <td>@(item.IsActive ? "Active" : "Inactive")</td>
                        <td><a asp-action="Edit" asp-route-id="@item.Id" class="btn btn-sm btn-outline-secondary">Edit</a></td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>
