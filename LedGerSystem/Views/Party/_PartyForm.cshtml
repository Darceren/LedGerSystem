@model PartyEditViewModel
@using LedGerSystem.Controllers

<div class="row justify-content-center">
    <div class="col-lg-6">
        <div class="card border-0 shadow-sm">
            <div class="card-body">
                <h1 class="h5 mb-3">@ViewData["Title"]</h1>
                <form method="post">
                    @Html.AntiForgeryToken()
                    <input type="hidden" asp-for="Id" />
                    <div asp-validation-summary="ModelOnly" class="text-danger mb-2"></div>

                    <div class="mb-3">
                        <label asp-for="Code" class="form-label"></label>
                        <input asp-for="Code" class="form-control" />
                        <span asp-validation-for="Code" class="text-danger small"></span>
                    </div>
                    <div class="mb-3">
                        <label asp-for="Name" class="form-label"></label>
                        <input asp-for="Name" class="form-control" />
                        <span asp-validation-for="Name" class="text-danger small"></span>
                    </div>
                    <div class="mb-3">
                        <label asp-for="PartyType" class="form-label"></label>
                        <select asp-for="PartyType" asp-items="PartySelectLists.PartyTypes()" class="form-select"></select>
                    </div>
                    <div class="mb-3">
                        <label asp-for="FinalAccountSide" class="form-label"></label>
                        <select asp-for="FinalAccountSide" asp-items="PartySelectLists.FinalAccountSides()" class="form-select"></select>
                    </div>
                    <div class="mb-3">
                        <label asp-for="ContactPhone" class="form-label"></label>
                        <input asp-for="ContactPhone" class="form-control" />
                    </div>
                    <div class="mb-3">
                        <label asp-for="SortOrder" class="form-label"></label>
                        <input asp-for="SortOrder" class="form-control" type="number" />
                    </div>
                    <div class="mb-3 form-check">
                        <input asp-for="IsActive" class="form-check-input" />
                        <label asp-for="IsActive" class="form-check-label"></label>
                    </div>
                    <div class="mb-3">
                        <label asp-for="Remark" class="form-label"></label>
                        <textarea asp-for="Remark" class="form-control" rows="2"></textarea>
                    </div>
                    <div class="d-flex gap-2">
                        <button type="submit" class="btn btn-primary">Save</button>
                        <a asp-action="Index" asp-route-type="@Model.PartyType" class="btn btn-outline-secondary">Cancel</a>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
